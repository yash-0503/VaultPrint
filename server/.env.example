# Port for HTTP + Socket.io (same server)
PORT=4000

# Session code length: 6 (default) or 8. Must match web NEXT_PUBLIC_SESSION_CODE_LENGTH.
SESSION_CODE_LENGTH=6

# Comma-separated list of allowed browser origins, or "*" for development only.
# Production (NODE_ENV=production): MUST be set to explicit origins — "*" causes the server to exit.
# Example: https://vaultprint.example.com,http://localhost:3000
CORS_ORIGINS=http://localhost:3000
